# Python cache / bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
.nox/
.coverage*
htmlcov/

# Virtual environments
.venv/
.venv-dory/
venv/
env/

# Local environment files
.env
.env.*
!.env.example
.python-version

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Build outputs
build/
dist/
site/

# Historical/generated analysis archives (keep canonical current outputs tracked)
analysis/outputs/history/
analysis/outputs/benchmarks/archive/
analysis/outputs/benchmarks/cache_features/
analysis/outputs/next_steps/archive/
analysis/outputs/planning_simulations/archive/

# Notebook / temp
.ipynb_checkpoints/
*.log
*.tmp
tmp/
.cache/

# Local runtime artifacts for ASReview LAB integration
infra/asreview-lab/data/*.csv
!infra/asreview-lab/data/*.example.csv
!infra/asreview-lab/data/.gitkeep

integration/outputs/*
